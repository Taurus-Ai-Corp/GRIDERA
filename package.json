{
  "name": "gridera-platform",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:brand": "bash scripts/check-brand.sh --all",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:funnel-unit": "tsx --test scripts/funnel-smoke/lib.test.ts",
    "smoke:funnel": "tsx scripts/funnel-smoke.ts",
    "smoke:comply-flow": "tsx scripts/smoke-comply-flow.ts",
    "probe:ca": "tsx scripts/ca-cell-probe.ts",
    "agents:funnel-qa": "bash scripts/agents/funnel-qa.sh",
    "agents:cell-health": "bash scripts/agents/cell-health.sh",
    "agents:hierarchy": "bash scripts/agents/hierarchy-compare.sh",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  }
}
